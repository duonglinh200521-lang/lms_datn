# Dependencies & build artifacts
**/node_modules/
**/dist/
**/build/
**/*.tsbuildinfo

# Environment & secrets (copy from .env.example if you add one)
**/.env
**/.env.local
**/.env.*.local

# Logs & coverage
**/logs/
**/*.log
**/coverage/
**/.nyc_output/
**/.cache/

# Editor / OS
.idea/
.vscode/
!.vscode/extensions.json
.DS_Store
Thumbs.db
*.swp
*.tmp

# Microsoft Office lock files
~$*

# Lock / debug noise (optional — remove next line if you want to commit debug logs)
pnpm-debug.log*
yarn-error.log*
npm-debug.log*
